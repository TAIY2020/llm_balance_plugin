{
  "manifest_version": 2,
  "version": "1.5.2",
  "name": "LLM 平台余额查询插件 | LLM Balance Plugin",
  "description": "通过聊天命令 /余额 并行查询 DeepSeek、SiliconFlow 的账号余额，支持 HTML 卡片可视化输出，仅依赖 Python 标准库。",
  "author": {
    "name": "TaiYang",
    "url": "https://github.com/TAIY2020"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/TAIY2020/llm_balance_plugin",
    "homepage": "https://github.com/TAIY2020/llm_balance_plugin",
    "documentation": "https://github.com/TAIY2020/llm_balance_plugin",
    "issues": "https://github.com/TAIY2020/llm_balance_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "render.html2png"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "TAIY2020.llm-balance-plugin"
}
